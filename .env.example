# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=dast
POSTGRES_USER=dast
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
