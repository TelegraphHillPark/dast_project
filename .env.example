# ── Скопируй в .env.prod и заполни реальными значениями ─────────────────────
# НЕ коммить .env.prod в git!

# Postgres
POSTGRES_DB=dast
POSTGRES_USER=dast
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# App
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ENVIRONMENT=production

# Домен или белый IP для nginx/SSL.
# Варианты:
#   Только IP (self-signed cert):   DOMAIN=1.2.3.4
#   Бесплатный DNS без домена:      DOMAIN=1.2.3.4.nip.io  (работает с Let's Encrypt)
#   Купленный домен:                DOMAIN=example.com
DOMAIN=YOUR_SERVER_IP

FRONTEND_URL=https://${DOMAIN}
ALLOWED_ORIGINS=https://${DOMAIN}

# OAuth GitHub (опционально)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# DVWA
DVWA_DB_ROOT_PASSWORD=CHANGE_ME_dvwa_root
DVWA_DB_PASSWORD=CHANGE_ME_dvwa_pass
