# ── Скопируй в .env.prod и заполни реальными значениями ─────────────────────
# НЕ коммить .env.prod в git!

# Postgres
POSTGRES_DB=dast
POSTGRES_USER=dast
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# App
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ENVIRONMENT=production
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com

# OAuth GitHub (опционально)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# DVWA
DVWA_DB_ROOT_PASSWORD=CHANGE_ME_dvwa_root
DVWA_DB_PASSWORD=CHANGE_ME_dvwa_pass
