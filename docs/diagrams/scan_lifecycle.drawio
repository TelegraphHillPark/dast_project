        <!-- running → paused -->
        <mxCell id="t_rp" value="POST /pause" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="running" target="paused" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- paused → pending (resume) -->
