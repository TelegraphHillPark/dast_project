        <!-- Transitions -->
        <!-- start → pending -->
        <mxCell id="t_start" value="POST /scans" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="start" target="pending" parent="1">
          <mxGeometry relative="1" as="geometry" />
